    LTEXT           "Name:", -1, 14, 40, 50, 8
    EDITTEXT        IDC_EDIT_SOURCE_NAME, 70, 38, 156, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK", IDOK, 120, 72, 50, 18
    PUSHBUTTON      "Cancel", IDCANCEL, 176, 72, 50, 18
END

